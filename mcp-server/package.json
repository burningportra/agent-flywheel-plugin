{
  "name": "agent-flywheel-mcp",
  "version": "3.9.0",
  "description": "MCP server for agent-flywheel — state + CLI glue for the agentic coding flywheel",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.scripts.json && npm run build:bundle",
    "build:bundle": "node dist/scripts/build-skills-bundle.js",
    "check:skills-bundle": "node dist/scripts/check-skills-bundle.js",
    "bead-viewer": "node dist/scripts/bead-viewer.js",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint:skill": "tsx scripts/lint-skill.ts --file ../skills/start/SKILL.md --baseline .lintskill-baseline.json",
    "lint:skill:json": "tsx scripts/lint-skill.ts --file ../skills/start/SKILL.md --ci --format json",
    "lint:skill:update-baseline": "tsx scripts/lint-skill.ts --file ../skills/start/SKILL.md --update-baseline --baseline .lintskill-baseline.json",
    "lint:skill:update-manifest": "tsx scripts/lint-skill.ts --update-manifest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sinclair/typebox": "^0.34.0",
    "execa": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^29.1.0",
    "remark-parse": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "unified": "^11.0.0",
    "vitest": "^2.0.0"
  }
}
