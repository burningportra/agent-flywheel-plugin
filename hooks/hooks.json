{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/startup.js 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "flywheel_approve_beads",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Bead approval processed. Run /agent-flywheel:flywheel-status to check progress.'"
          }
        ]
      }
    ]
  }
}
